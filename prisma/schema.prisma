/// ตารางเก็บข้อมูลหลักของใบขอซื้อ (Purchase Requisition Header) (P1)
model pr_header {
    /// รหัสใบขอซื้อ (PK)
    pr_id        Int      @id @default(autoincrement())
    /// เลขที่ใบขอซื้อ
    pr_no        String   @unique @db.VarChar(50)
    /// เลขใบเสนอราคาจาก vender ที่ต้องการ
    quotation_no String?  @db.VarChar(30)
    /// รหัสสาขา (FK)
    branch_id    Int?
    /// สถานะ
    status       String   @db.VarChar(30)
    /// วันที่สร้าง
    created_at   DateTime @default(now())

    /// สกุลเงินที่ใช้ทำรายการ (Base Currency)
    pr_base_currency_code  String?   @db.VarChar(3)
    /// สกุลเงินที่ใช้ทำรายการ (Quote Currency)
    pr_quote_currency_code String?   @db.VarChar(3)
    /// อัตราแลกเปลี่ยน (1 quote → base) ui input
    pr_exchange_rate       Decimal?  @db.Decimal(18, 6)
    /// วันที่ของเรท ui input
    pr_exchange_rate_date  DateTime?
    /// จำนวนเงินรวม (Base Currency)
    pr_base_total_amount   Decimal   @db.Decimal(18, 2)
    /// จำนวนเงินรวม (Quote Currency)
    pr_quote_total_amount  Decimal   @db.Decimal(18, 2)
    /// ภาษี (Base Currency)
    pr_tax_amount          Decimal?  @db.Decimal(18, 2)
    /// อัตราภาษี
    pr_tax_rate            Decimal?  @db.Decimal(9, 4)
    /// รหัสกลุ่มภาษี (FK)
    pr_tax_code_id         Int?
    pr_tax_code            tax_code? @relation(fields: [pr_tax_code_id], references: [tax_code_id])
    /// ส่วนลดทั้งเอกสาร (string) จาก pr_line:line_amount
    pr_discount_raw        String?   @db.VarChar(30)
    /// % ส่วนลดทั้งเอกสาร (คำนวณจาก pr_discount_raw)
    pr_discount_rate       Decimal?  @db.Decimal(9, 4)
    /// จำนวนเงินส่วนลดทั้งเอกสาร (คำนวณจาก pr_discount_raw)
    pr_discount_amount     Decimal?  @db.Decimal(18, 2)

    /// วันที่ต้องการ
    need_by_date      DateTime?
    /// เครดิตเทอม (วัน)
    payment_term_days Int?
    /// วันที่สร้างใบขอซื้อ
    pr_date           DateTime
    /// หมายเหตุ
    remark            String?
    /// วันที่แก้ไขล่าสุด
    updated_at        DateTime  @updatedAt

    /// วันเครดิต
    credit_days   Int?
    /// วันที่ส่งมอบที่ต้องการ
    delivery_date DateTime?

    onhold              Boolean @default(false)
    cancel_flag         Boolean @default(false)
    /// ผู้ขายที่แนะนำ
    preferred_vendor    String? @db.VarChar(100)
    /// ผู้ขอ
    requester_name      String? @db.VarChar(100)
    /// รหัสผู้ขอ (FK)
    requester_user_id   Int
    /// วิธีการจัดส่ง
    shipping_method     String? @db.VarChar(100)
    /// เลขที่ใบเสนอราคาจากผู้ขาย
    vendor_quote_no     String? @db.VarChar(100)
    /// รหัสผู้ขายที่แนะนำ (FK)
    preferred_vendor_id Int?
    /// รหัสโครงการ (FK)
    project_id          Int?
    /// ผู้อนุมัติ
    approved_by_user_id Int?

    cost_center_id Int?

    /// วันที่อนุมัติ
    approved_at DateTime?
    /// เวอร์ชั่น
    version     Int       @default(1)

    /// ผู้อนุมัติ
    approved_by_user employees?    @relation("approved_by_user", fields: [approved_by_user_id], references: [employee_id])
    preferredVendor  vendor?       @relation(fields: [preferred_vendor_id], references: [vendor_id])
    branch           org_branch?   @relation(fields: [branch_id], references: [branch_id])
    requester_user   employees     @relation("requester_user", fields: [requester_user_id], references: [employee_id])
    project          project?      @relation(fields: [project_id], references: [project_id])
    cost_center      cost_center?  @relation(fields: [cost_center_id], references: [cost_center_id])
    prLines          pr_line[]
    rfqHeaders       rfq_header[]  @relation("PRtoRFQ")
    vqHeaders        vq_header[]
    qcHeaders        qc_header[]
    poHeaders        po_header[]
    prApprovals      pr_approval[]

    @@map("pr_header")
}

/// ตารางเก็บข้อมูลรายละเอียดของใบขอซื้อ (Purchase Requisition Line) (P2)
model pr_line {
    /// รหัสใบขอซื้อ (PK)
    pr_line_id           Int      @id @default(autoincrement())
    /// ลำดับ
    line_no              Int
    /// รหัสสินค้า (FK)
    item_id              Int?
    /// รายละเอียด
    description          String?
    /// รหัสคลัง (FK)
    warehouse_id         Int?
    /// ตำแหน่งสินค้า
    location             String?  @db.VarChar(50)
    /// รหัสตำแหน่งที่เก็บคลังสินค้า
    location_id          Int?
    /// รหัสใบขอซื้อ (FK)
    pr_id                Int
    /// จำนวน
    qty                  Decimal  @db.Decimal(18, 3)
    /// รหัสหน่วยนับ (FK)
    uom_id               Int
    /// ราคาต่อหน่วยโดยประมาณ
    est_unit_price       Decimal  @db.Decimal(18, 6)
    /// รหัสกลุ่มภาษี (FK)
    tax_code_id          Int?
    /// อัตราภาษี
    tax_rate             Decimal? @db.Decimal(9, 4)
    /// ภาษี
    tax_amount           Decimal? @db.Decimal(18, 4)
    /// ส่วนลดต่อบรรทัด (string) จาก UI
    line_discount_raw    String?  @db.VarChar(10)
    /// % ส่วนลดต่อบรรทัด (คำนวณจาก line_discount_raw)
    line_discount_rate   Decimal? @db.Decimal(9, 4)
    /// จำนวนเงินส่วนลดต่อบรรทัด (คำนวณจาก line_discount_raw)
    line_discount_amount Decimal? @db.Decimal(18, 4)

    /// ยอดสุทธิต่อบรรทัด (หลังหักส่วนลด ยังไม่รวมภาษี)
    line_net_amount Decimal @db.Decimal(18, 4)

    /// จำนวนเงินต่อหน่วย (หลังหักส่วนลด รวมภาษี)
    line_amount Decimal @db.Decimal(18, 4)

    /// ประเภทการรับสินค้าที่ต้องการ GOODS/SERVICE
    required_receipt_type String? @db.VarChar(20)
    // ใช้ตรวจสอบอนุมัติ
    status                String? @db.VarChar(20)
    // จำนวนที่อนุมัติ
    approved_qty          Decimal @default(0)
    // จำนวนที่ปฏิเสธ
    rejected_qty          Decimal @default(0)
    // จำนวนที่ยังค้างอยู่จากการอนุมัติ
    remaining_qty         Decimal @default(0)

    item            item?              @relation(fields: [item_id], references: [item_id])
    pr              pr_header          @relation(fields: [pr_id], references: [pr_id])
    uom             uom                @relation(fields: [uom_id], references: [uom_id])
    warehouse       warehouse?         @relation(fields: [warehouse_id], references: [warehouse_id])
    locationId      location?          @relation(fields: [location_id], references: [location_id])
    tax_code        tax_code?          @relation(fields: [tax_code_id], references: [tax_code_id])
    rfqLines        rfq_line[]
    vqLines         vq_line[]
    poLines         po_line[]
    prApprovalLines pr_approval_line[]

    @@unique([pr_id, line_no])
    @@index([pr_id])
}

model pr_approval {
    approval_id       Int       @id @default(autoincrement())
    approval_no       String    @db.VarChar(30)
    approval_date     DateTime  @db.Date
    need_by_date      DateTime? @db.Date
    status            String    @db.VarChar(20)
    remarks           String?   @db.Text
    created_at        DateTime  @default(now())
    updated_at        DateTime  @updatedAt
    approval_emp_id   Int
    approval_emp_name String    @db.VarChar(255)

    pr_id Int

    /// สกุลเงินหลักของระบบ (Functional Currency)
    base_currency_code    String?   @db.VarChar(3)
    base_currency_id      Int?
    /// สกุลเงินตามใบเสนอราคา (Vendor Currency)
    quote_currency_code   String?   @db.VarChar(3)
    quote_currency_id     Int?
    /// อัตราแลกเปลี่ยน (1 quote → base) ui input
    exchange_rate         Decimal?  @db.Decimal(18, 6)
    /// วันที่ของเรท ui input
    exchange_rate_date    DateTime?
    /// จำนวนเงินรวม (Base Currency)
    base_total_amount     Decimal   @db.Decimal(18, 2)
    /// จำนวนเงินรวม (Quote Currency)
    quote_total_amount    Decimal   @db.Decimal(18, 2)
    /// TAX
    tax_code_id           Int?
    tax_rate              Decimal?  @db.Decimal(9, 4)
    base_tax_amount       Decimal?  @db.Decimal(18, 2)
    quote_tax_amount      Decimal?  @db.Decimal(18, 2)
    /// DOCUMENT DISCOUNT
    discount_expression   String?   @db.VarChar(20)
    discount_rate         Decimal?  @db.Decimal(9, 4)
    base_discount_amount  Decimal?  @db.Decimal(18, 2)
    quote_discount_amount Decimal?  @db.Decimal(18, 2)

    // 🔗 Relations (แนะนำให้มี)
    pr              pr_header          @relation(fields: [pr_id], references: [pr_id])
    approval_emp    employees          @relation(fields: [approval_emp_id], references: [employee_id])
    base_currency   currency?          @relation("pr_approval-base_currency", fields: [base_currency_id], references: [currency_id])
    quote_currency  currency?          @relation("pr_approval-quote_currency", fields: [quote_currency_id], references: [currency_id])
    tax_code        tax_code?          @relation(fields: [tax_code_id], references: [tax_code_id])
    prApprovalLines pr_approval_line[]
    rfqHeaders      rfq_header[]
    vqHeaders       vq_header[]

    @@map("pr_approval")
}

model pr_approval_line {
    approval_line_id Int @id @default(autoincrement())

    approved_qty Decimal @db.Decimal(18, 3)
    remarks      String? @db.Text

    pr_line_id  Int
    approval_id Int

    approved_at DateTime? // NULL = ยังไม่ approve

    // 🔗 relation
    approval pr_approval @relation(fields: [approval_id], references: [approval_id])
    pr_line  pr_line     @relation(fields: [pr_line_id], references: [pr_line_id])
    rfqLines rfq_line[]
    vqLines  vq_line[]

    @@map("approval_pr_line")
}

/// ตารางเก็บข้อมูลหลักของใบขอซื้อ (Purchase for Quotation Header) (P3)
model rfq_header {
    /// รหัสใบขอซื้อ (PK)
    rfq_id               Int       @id @default(autoincrement())
    /// เลขที่ใบขอซื้อ
    rfq_no               String    @unique @db.VarChar(30)
    /// วันที่สร้างใบขอซื้อ
    rfq_date             DateTime
    /// รหัสผู้ขอ
    requested_by_user_id Int
    /// รหัสใบขอซื้อ (FK)
    pr_id                Int
    pr_approval_id       Int?
    /// รหัสสาขา (FK)
    branch_id            Int?
    /// ผู้ขอ
    requested_by         String    @db.VarChar(50)
    /// สถานะ
    status               String    @db.VarChar(20)
    /// วันที่ต้องการ (กำหนดส่งใบเสนอราคา)
    quotation_due_date   DateTime?

    /// สกุลเงินที่ใช้ทำรายการ (Base Currency)
    rfq_base_currency_code  String?   @db.VarChar(3)
    /// สกุลเงินที่ใช้ทำรายการ (Quote Currency)
    rfq_quote_currency_code String?   @db.VarChar(3)
    /// อัตราแลกเปลี่ยน (1 quote → base) ui input
    rfq_exchange_rate       Decimal?  @db.Decimal(18, 6)
    /// วันที่ของเรท ui input
    rfq_exchange_rate_date  DateTime?

    /// สถานที่รับสินค้า
    receive_location  String?
    /// เงื่อนไขการชำระเงิน
    payment_term_hint String? @db.VarChar(20)
    /// เงื่อนไขการส่งมอบ (กรณีนำเข้า FOB, CIF,EXW, etc) 
    incoterm          String? @db.VarChar(20)
    /// หมายเหตุ
    remarks           String?

    created_at        DateTime     @default(now())
    updated_at        DateTime     @updatedAt
    branch            org_branch?  @relation(fields: [branch_id], references: [branch_id])
    requested_by_user employees    @relation("requested_by_user", fields: [requested_by_user_id], references: [employee_id])
    pr                pr_header    @relation("PRtoRFQ", fields: [pr_id], references: [pr_id])
    pr_approval       pr_approval? @relation(fields: [pr_approval_id], references: [approval_id])
    rfqLines          rfq_line[]
    rfqVendors        rfq_vendor[]
    vqHeaders         vq_header[]
    qcHeaders         qc_header[]
}

/// ตารางเก็บข้อมูลหลักของใบขอซื้อ (Purchase for Quotation Line) (P4)
model rfq_line {
    /// รหัสใบขอซื้อ (PK)
    rfq_line_id      Int     @id @default(autoincrement())
    /// รหัสใบขอซื้อ (FK)
    rfq_id           Int
    approval_line_id Int?
    /// ลำดับ
    line_no          Int
    /// รหัสสินค้า (FK)
    pr_line_id       Int
    /// รหัสสินค้า (FK)
    item_id          Int?
    /// รายละเอียด
    description      String? @db.VarChar(255)

    /// จำนวน
    qty    Decimal @default(0) @db.Decimal(18, 6)
    /// รหัสหน่วยนับ (FK)
    uom_id Int

    /// ประเภทการรับเอกสาร (Service, Material) 
    required_receipt_type String?   @db.VarChar(20)
    /// วันที่ต้องการ
    target_delivery_date  DateTime?
    /// หมายเหตุถึงผู้ขาย
    note_to_vendor        String?   @db.Text

    item             item?             @relation(fields: [item_id], references: [item_id])
    rfq              rfq_header        @relation(fields: [rfq_id], references: [rfq_id])
    uom              uom               @relation(fields: [uom_id], references: [uom_id])
    pr_line          pr_line           @relation(fields: [pr_line_id], references: [pr_line_id])
    pr_approval_line pr_approval_line? @relation(fields: [approval_line_id], references: [approval_line_id])
    poLines          po_line[]

    @@index([rfq_id])
}

/// ตารางเก็บข้อมูลผู้ขายที่ถูกเชิญให้เสนอราคา (RFQ Vendor) (P5) 
model rfq_vendor {
    rfq_vendor_id Int         @id @default(autoincrement())
    rfq_id        Int
    vendor_id     Int
    status        String?     @db.VarChar(20)
    is_active     Boolean?    @default(true)
    //วันที่เชิญ
    invited_at    DateTime?
    //วันที่ส่งใบเสนอราคา
    sent_at       DateTime?
    //วันที่ตอบกลับใบเสนอราคา
    responded_at  DateTime?
    contact_email String?     @db.VarChar(255)
    //วันที่สร้าง
    created_at    DateTime    @default(now())
    //วันที่อัปเดต
    updated_at    DateTime    @updatedAt
    //หมายเหตุ
    note          String?     @db.Text
    rfq           rfq_header  @relation(fields: [rfq_id], references: [rfq_id])
    vendor        vendor      @relation(fields: [vendor_id], references: [vendor_id])
    vq_header     vq_header[]

    @@index([rfq_id])
}

model vq_header {
    /// รหัสใบเสนอราคา (PK)
    vq_header_id   Int     @id @default(autoincrement())
    /// เลขที่ใบเสนอราคา
    vq_no          String  @unique @db.VarChar(30)
    /// เลขที่ใบเสนอราคาจากผู้ขาย
    quotation_no   String? @db.VarChar(30)
    /// รหัสใบขอซื้อ (FK)
    pr_id          Int
    pr_approval_id Int?
    /// รหัสใบขอซื้อ (FK)
    rfq_id         Int

    rfq_vendor_id Int?
    /// รหัสผู้ขาย (FK)
    vendor_id     Int
    contact_name  String? @db.VarChar(255)
    contact_phone String? @db.VarChar(255)
    contact_email String? @db.VarChar(255)

    /// วันที่เสนอราคา
    quotation_date        DateTime  @default(now())
    /// วันที่หมดอายุของใบเสนอราคา
    quotation_expiry_date DateTime?
    /// ระยะเวลาส่งมอบ (จำนวนวัน)
    lead_time_days        Int?
    /// สถานะ
    status                String    @db.VarChar(20)
    /// เงื่อนไขการชำระเงิน
    payment_term_days     Int?

    /// สกุลเงินหลักของระบบ (Functional Currency)
    base_currency_code  String?   @db.VarChar(3)
    /// สกุลเงินตามใบเสนอราคา (Vendor Currency)
    quote_currency_code String?   @db.VarChar(3)
    /// อัตราแลกเปลี่ยน (1 quote → base) ui input
    exchange_rate       Decimal?  @db.Decimal(18, 6)
    /// วันที่ของเรท ui input
    exchange_rate_date  DateTime?

    /// จำนวนเงินรวม (Base Currency)
    base_total_amount  Decimal @db.Decimal(18, 2)
    /// จำนวนเงินรวม (Quote Currency)
    quote_total_amount Decimal @db.Decimal(18, 2)

    /// TAX
    tax_code_id      Int?
    tax_rate         Decimal? @db.Decimal(9, 4)
    base_tax_amount  Decimal? @db.Decimal(18, 2)
    quote_tax_amount Decimal? @db.Decimal(18, 2)

    /// DOCUMENT DISCOUNT
    discount_expression   String?      @db.VarChar(20)
    discount_rate         Decimal?     @db.Decimal(9, 4)
    base_discount_amount  Decimal?     @db.Decimal(18, 2)
    quote_discount_amount Decimal?     @db.Decimal(18, 2)
    created_by            Int?
    updated_by            Int?
    created_at            DateTime     @default(now())
    updated_at            DateTime     @updatedAt
    //ใช้ตอน qc
    is_awarded            Boolean      @default(false)
    pr                    pr_header    @relation(fields: [pr_id], references: [pr_id])
    rfq                   rfq_header   @relation(fields: [rfq_id], references: [rfq_id])
    rfq_vendor            rfq_vendor?  @relation(fields: [rfq_vendor_id], references: [rfq_vendor_id])
    vendor                vendor       @relation(fields: [vendor_id], references: [vendor_id])
    tax_code              tax_code?    @relation(fields: [tax_code_id], references: [tax_code_id])
    createdVqHeaders      employees?   @relation("VQCreatedBy", fields: [created_by], references: [employee_id])
    updatedVqHeaders      employees?   @relation("VQUpdatedBy", fields: [updated_by], references: [employee_id])
    pr_approval           pr_approval? @relation(fields: [pr_approval_id], references: [approval_id])
    vqLines               vq_line[]
    qcHeaders             qc_header[]
}

model vq_line {
    /// รหัสใบเสนอราคา (PK)
    vq_line_id   Int  @id @default(autoincrement())
    vq_header_id Int
    /// ลำดับ
    line_no      Int
    /// รหัสสินค้า (FK)
    item_id      Int?
    /// รหัสใบขอซื้อ (FK)
    pr_line_id   Int

    approval_line_id Int?
    /// รายละเอียด
    description      String? @db.VarChar(255)

    /// สถานะ
    status              String            @db.VarChar(20)
    /// จำนวน
    qty                 Decimal           @db.Decimal(18, 6)
    /// รหัสหน่วยนับ (FK)
    uom_id              Int
    /// ราคาต่อหน่วย
    unit_price          Decimal           @db.Decimal(18, 2)
    /// ส่วนลดต่อบรรทัด 
    discount_amount     Decimal?          @db.Decimal(9, 4)
    /// % ส่วนลด(string) 
