    /// รหัสใบขอซื้อ (FK)
    rfq_id         Int

    rfq_vendor_id Int?
    /// รหัสผู้ขาย (FK)
    vendor_id     Int
    contact_name  String? @db.VarChar(255)
    contact_phone String? @db.VarChar(255)
    contact_email String? @db.VarChar(255)

