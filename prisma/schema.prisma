    discount_amount     Decimal? @db.Decimal(18, 2)
    discount_rate       Decimal? @db.Decimal(9, 4)

    net_amount     Decimal           @db.Decimal(18, 2)
    saleOrderLines sale_order_line[]
}

// D9
model sale_order_header {
    so_id              Int                     @id @default(autoincrement())
    so_no              String                  @unique
    so_date            DateTime                @default(now())
    reservation_id     Int
    reservation_header sale_reservation_header @relation(fields: [reservation_id], references: [reservation_id])
    customer_id        Int
    customer           customer                @relation(fields: [customer_id], references: [customer_id])
    branch_id          Int
    branch             org_branch              @relation(fields: [branch_id], references: [branch_id])
    status             String
    ship_days          Int                     @default(0)
    ship_date          DateTime?               @db.Date
    remarks            String
    payment_term_days  Int                     @default(0)
    onhold             String
    emp_sale_id        Int?
    emp_sale           employees?              @relation(fields: [emp_sale_id], references: [employee_id])
    sale_area_id       Int
    sale_area          employee_sale_area      @relation(fields: [sale_area_id], references: [sale_area_id])
    emp_dept_id        Int
    emp_dept           employee_department     @relation(fields: [emp_dept_id], references: [emp_dept_id])
    project_id         Int
    project            project                 @relation(fields: [project_id], references: [project_id])
    status_remark      String

    /// สกุลเงินหลักของระบบ (Functional Currency)
    base_currency_code    String?   @db.VarChar(3)
    /// สกุลเงินตามใบเสนอราคา (Vendor Currency)
    quote_currency_code   String?   @db.VarChar(3)
    /// อัตราแลกเปลี่ยน (1 quote → base) ui input
    exchange_rate         Decimal?  @db.Decimal(18, 6)
    /// วันที่ของเรท ui input
    exchange_rate_date    DateTime?
    /// จำนวนเงินรวม (Base Currency)
    base_total_amount     Decimal   @db.Decimal(18, 2)
    /// จำนวนเงินรวม (Quote Currency)
    quote_total_amount    Decimal   @db.Decimal(18, 2)
    /// TAX
    tax_code_id           Int?
    tax_code              tax_code? @relation(fields: [tax_code_id], references: [tax_code_id])
    tax_rate              Decimal?  @db.Decimal(9, 4)
    base_tax_amount       Decimal?  @db.Decimal(18, 2)
    quote_tax_amount      Decimal?  @db.Decimal(18, 2)
    /// DOCUMENT DISCOUNT
    discount_expression   String?   @db.VarChar(20)
    discount_rate         Decimal?  @db.Decimal(9, 4)
    base_discount_amount  Decimal?  @db.Decimal(18, 2)
    quote_discount_amount Decimal?  @db.Decimal(18, 2)

    cust_po_no   String?
    cust_po_date DateTime?

    saleOrderLines           sale_order_line[]
    saleOrderApprovalHeaders sale_order_approval_header[]
}

// D10
model sale_order_line {
    so_line_id          Int                   @id @default(autoincrement())
    so_id               Int
    so_header           sale_order_header     @relation(fields: [so_id], references: [so_id])
    reservation_line_id Int
    reservation_line    sale_reservation_line @relation(fields: [reservation_line_id], references: [reservation_line_id])
    item_id             Int
    item                item                  @relation(fields: [item_id], references: [item_id])
    warehouse_id        Int?
    warehouse           warehouse?            @relation(fields: [warehouse_id], references: [warehouse_id])
    location_id         Int?
    location            location?             @relation(fields: [location_id], references: [location_id])
    note                String?               @db.Text
    lot_id              Int?
    lot                 item_lot?             @relation(fields: [lot_id], references: [lot_id])

    /// สถานะ
    status     String   @default("PENDING") @db.VarChar(20)
    /// วันที่สร้าง
    created_at DateTime @default(now())
    /// วันที่แก้ไขล่าสุด
    updated_at DateTime @updatedAt
    /// จำนวนที่สั่งซื้อ
    qty        Decimal  @db.Decimal(18, 6)
    /// หน่วยนับ
    uom_id     Int
    uom        uom      @relation(fields: [uom_id], references: [uom_id])
    /// ราคาต่อหน่วย
    unit_price Decimal  @db.Decimal(18, 6)

    /// DOCUMENT DISCOUNT    /// ส่วนลด
    discount_expression String?  @db.VarChar(20)
    discount_amount     Decimal? @db.Decimal(18, 6)
    discount_rate       Decimal? @db.Decimal(9, 6)

    net_amount Decimal @db.Decimal(18, 6)

    // จำนวนที่อนุมัติ
    approved_qty  Decimal @default(0)
    // จำนวนที่ปฏิเสธ
    rejected_qty  Decimal @default(0)
    // จำนวนที่ยังค้างอยู่จากการอนุมัติ
    remaining_qty Decimal @default(0)

    saleOrderApprovalLines sale_order_approval_line[]
}

model sale_order_approval_header {
    so_approval_id   Int      @id @default(autoincrement())
    so_approval_no   String   @unique @db.VarChar(30)
    so_approval_date DateTime @db.Date

    so_id     Int
    so_header sale_order_header @relation(fields: [so_id], references: [so_id])

    status  String  @db.VarChar(20)
    remarks String? @db.Text

    created_at DateTime @default(now())
    updated_at DateTime @updatedAt

    approval_emp_id   Int
    approval_emp      employees @relation("emp_so_approval_header", fields: [approval_emp_id], references: [employee_id])
    approval_emp_name String    @db.VarChar(255)

    customer_id       Int
    customer          customer            @relation(fields: [customer_id], references: [customer_id])
    branch_id         Int
    branch            org_branch          @relation(fields: [branch_id], references: [branch_id])
    ship_days         Int                 @default(0)
    payment_term_days Int                 @default(0)
    onhold            String
    emp_sale_id       Int?
    emp_sale          employees?          @relation("emp_so_sale_header", fields: [emp_sale_id], references: [employee_id])
    sale_area_id      Int
    sale_area         employee_sale_area  @relation(fields: [sale_area_id], references: [sale_area_id])
    emp_dept_id       Int
    emp_dept          employee_department @relation(fields: [emp_dept_id], references: [emp_dept_id])
    project_id        Int
    project           project             @relation(fields: [project_id], references: [project_id])
    status_remark     String

    /// สกุลเงินหลักของระบบ (Functional Currency)
    base_currency_code    String?   @db.VarChar(3)
    /// สกุลเงินตามใบเสนอราคา (Vendor Currency)
    quote_currency_code   String?   @db.VarChar(3)
    /// อัตราแลกเปลี่ยน (1 quote → base) ui input
    exchange_rate         Decimal?  @db.Decimal(18, 6)
    /// วันที่ของเรท ui input
    exchange_rate_date    DateTime?
    /// จำนวนเงินรวม (Base Currency)
    base_total_amount     Decimal   @db.Decimal(18, 2)
    /// จำนวนเงินรวม (Quote Currency)
    quote_total_amount    Decimal   @db.Decimal(18, 2)
    /// TAX
    tax_code_id           Int?
    tax_code              tax_code? @relation(fields: [tax_code_id], references: [tax_code_id])
    tax_rate              Decimal?  @db.Decimal(9, 4)
    base_tax_amount       Decimal?  @db.Decimal(18, 2)
    quote_tax_amount      Decimal?  @db.Decimal(18, 2)
    /// DOCUMENT DISCOUNT
    discount_expression   String?   @db.VarChar(20)
    discount_rate         Decimal?  @db.Decimal(9, 4)
    base_discount_amount  Decimal?  @db.Decimal(18, 2)
    quote_discount_amount Decimal?  @db.Decimal(18, 2)

    saleOrderApprovalLines sale_order_approval_line[]
}

model sale_order_approval_line {
    so_approval_line_id Int @id @default(autoincrement())

    so_approval_id Int
    so_approval    sale_order_approval_header @relation(fields: [so_approval_id], references: [so_approval_id])

    so_line_id Int
    so_line    sale_order_line @relation(fields: [so_line_id], references: [so_line_id])
    item_id    Int
    item       item            @relation(fields: [item_id], references: [item_id])

    remarks String? @db.Text

    /// จำนวนที่อนุมัติ
    approved_qty Decimal @db.Decimal(18, 3)

    /// วันที่สร้าง
    created_at DateTime @default(now())
    /// วันที่แก้ไขล่าสุด
    updated_at DateTime @updatedAt
    /// จำนวนที่สั่งซื้อ 
    qty        Decimal  @db.Decimal(18, 6)
    /// หน่วยนับ
    uom_id     Int
    uom        uom      @relation(fields: [uom_id], references: [uom_id])
    /// ราคาต่อหน่วย
    unit_price Decimal  @db.Decimal(18, 6)

    /// DOCUMENT DISCOUNT    /// ส่วนลด
    discount_expression String?  @db.VarChar(20)
    discount_amount     Decimal? @db.Decimal(18, 6)
    discount_rate       Decimal? @db.Decimal(9, 6)

    net_amount Decimal @db.Decimal(18, 6)
}

// =========================
// ITEM STOCK BALANCE
// =========================
// M4.4 ยังไม่ใช้เนื่องจากปัญหาทีมสับสนและระยะเวลา
model item_stock_balance {
    stock_balance_id Int @id @default(autoincrement())

    item_id      Int
    branch_id    Int?
    warehouse_id Int
    location_id  Int?

    qty_on_hand   Decimal @default(0) @db.Decimal(18, 6)
    qty_reserved  Decimal @default(0) @db.Decimal(18, 6)
    qty_available Decimal @default(0) @db.Decimal(18, 6)

    updated_at DateTime @updatedAt

    item      item        @relation(fields: [item_id], references: [item_id])
    branch    org_branch? @relation(fields: [branch_id], references: [branch_id])
    warehouse warehouse   @relation(fields: [warehouse_id], references: [warehouse_id])
    location  location?   @relation(fields: [location_id], references: [location_id])

    @@unique([item_id, branch_id, warehouse_id, location_id])
    @@index([item_id])
    @@index([warehouse_id])
}

// =========================
// STOCK TRANSACTION (ITEM LEVEL)
// =========================
// M4.3 ยังไม่ใช้เนื่องจากปัญหาทีมสับสนและระยะเวลา
model stock_transaction {
    stock_transaction_id Int @id @default(autoincrement())

    item_id      Int
    branch_id    Int?
    warehouse_id Int
    location_id  Int?

    qty Decimal @db.Decimal(18, 6)

    trans_type String
    // RECEIVE / ISSUE / ADJUST / TRANSFER / RESERVE

    ref_doc_type String?
    ref_doc_no   String?
    ref_line_id  Int?

    created_at DateTime @default(now())

    item      item        @relation(fields: [item_id], references: [item_id])
    branch    org_branch? @relation(fields: [branch_id], references: [branch_id])
    warehouse warehouse   @relation(fields: [warehouse_id], references: [warehouse_id])
    location  location?   @relation(fields: [location_id], references: [location_id])

    @@index([item_id])
    @@index([warehouse_id])
    @@index([ref_doc_type, ref_doc_no])
}

// =========================
// ITEM LOT (MASTER)
// =========================
// M4
model item_lot {
    lot_id Int @id @default(autoincrement())

    item_id Int
    lot_no  String

    supplier_vendor_id Int?

    mfg_date    DateTime?
    expiry_date DateTime?

    status String @db.VarChar(20)

    note String?

    item            item    @relation(fields: [item_id], references: [item_id])
    supplier_vendor vendor? @relation(fields: [supplier_vendor_id], references: [vendor_id])

    balances             item_lot_balance[]
    transactions         lot_transaction[]
    saleReservationLines sale_reservation_line[]
    saleOrderLines       sale_order_line[]

    @@unique([item_id, lot_no])
    @@index([item_id])
    @@index([expiry_date])
}

// =========================
// ITEM LOT BALANCE
// =========================
// M4.1
model item_lot_balance {
    lot_balance_id Int @id @default(autoincrement())

    lot_id  Int
    item_id Int

    branch_id     Int?
    warehouse_id  Int
    location_id   Int
    // จำนวนคงเหลือจริงที่มีอยู่ใน lot / location นี้
    qty_on_hand   Decimal @default(0) @db.Decimal(18, 6)
    // จำนวนที่ถูกจองไว้แล้ว เช่น Sale Order / Reservation / Pending Issue
    qty_reserved  Decimal @default(0) @db.Decimal(18, 6)
    // จำนวนที่พร้อมใช้งานจริง = qty_on_hand - qty_reserved
    qty_available Decimal @default(0) @db.Decimal(18, 6)

    updated_at DateTime @updatedAt

    lot       item_lot    @relation(fields: [lot_id], references: [lot_id])
    item      item        @relation(fields: [item_id], references: [item_id])
    branch    org_branch? @relation(fields: [branch_id], references: [branch_id])
    warehouse warehouse   @relation(fields: [warehouse_id], references: [warehouse_id])
    location  location    @relation(fields: [location_id], references: [location_id])

    @@unique([lot_id, warehouse_id, location_id])
    @@index([item_id])
    @@index([warehouse_id])
}

// =========================
// LOT TRANSACTION
// =========================
// M4.2
model lot_transaction {
    lot_transaction_id Int @id @default(autoincrement())

    lot_id  Int
    item_id Int

    branch_id    Int?
    warehouse_id Int
    location_id  Int

    qty Decimal @db.Decimal(18, 6)

    trans_type String
    // RECEIVE / ISSUE / RESERVE / ADJUST

    ref_doc_type String?
    ref_doc_no   String?
    ref_line_id  Int?

    created_at DateTime @default(now())

    lot       item_lot    @relation(fields: [lot_id], references: [lot_id])
    item      item        @relation(fields: [item_id], references: [item_id])
    branch    org_branch? @relation(fields: [branch_id], references: [branch_id])
    warehouse warehouse   @relation(fields: [warehouse_id], references: [warehouse_id])
    location  location?   @relation(fields: [location_id], references: [location_id])

    @@index([lot_id])
    @@index([item_id])
    @@index([warehouse_id])
    @@index([ref_doc_type, ref_doc_no])
}

