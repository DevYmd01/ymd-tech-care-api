    quotation_date        DateTime  @default(now())
    /// วันที่หมดอายุของใบเสนอราคา
    quotation_expiry_date DateTime?
    /// ระยะเวลาส่งมอบ (จำนวนวัน)
    lead_time_days        Int?
    /// สถานะ
    status                String    @db.VarChar(20)
    /// เงื่อนไขการชำระเงิน
    payment_term_days     Int?

    /// สกุลเงินหลักของระบบ (Functional Currency)
    base_currency_code  String?   @db.VarChar(3)
    /// สกุลเงินตามใบเสนอราคา (Vendor Currency)
    quote_currency_code String?   @db.VarChar(3)
    /// อัตราแลกเปลี่ยน (1 quote → base) ui input
