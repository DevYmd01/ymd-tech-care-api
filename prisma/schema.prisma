generator client {
    provider = "prisma-client-js"
}

datasource db {
    provider = "postgresql"
    url      = env("DATABASE_URL")
}

////////////
//// EP0 Master-data
////////////

model employees {
    employee_id                  Int                              @id @default(autoincrement())
    branch_id                    Int?
    employee_code                String                           @unique @db.VarChar(20)
    employee_title_th            String                           @db.VarChar(20)
    employee_title_en            String                           @db.VarChar(20)
    employee_firstname_th        String                           @db.VarChar(200)
    employee_lastname_th         String                           @db.VarChar(200)
    employee_firstname_en        String?                          @db.VarChar(200)
    employee_lastname_en         String?                          @db.VarChar(200)
    employee_fullname            String                           @db.VarChar(400)
    employee_startdate           DateTime
    employee_resigndate          DateTime?
    employee_status              String                           @db.VarChar(20)
    phone                        String?                          @db.VarChar(20)
    email                        String                           @db.VarChar(255)
    remark                       String?
    tax_idcard                   String?                          @db.VarChar(20)
    tax_id                       String?                          @db.VarChar(20)
    emp_type                     Boolean                          @default(false)
    position_id                  Int?
    department_id                Int?
    is_active                    Boolean                          @default(true)
    employee_head_id             Int?
    employee_head_code           String?                          @db.VarChar(25)
    created_at                   DateTime                         @default(now())
    updated_at                   DateTime                         @default(now()) @updatedAt
    employeeAddresses            employee_address[]
    employeeAuths                employee_auth?
    branch                       org_branch?                      @relation(fields: [branch_id], references: [branch_id])
    department                   org_department?                  @relation(fields: [department_id], references: [department_id])
    employeeHead                 employees?                       @relation("EmployeeManager", fields: [employee_head_id], references: [employee_id])
    employees                    employees[]                      @relation("EmployeeManager")
    position                     org_position?                    @relation(fields: [position_id], references: [position_id])
    requested_pr                 pr_header[]                      @relation("requester_user")
    approved_pr                  pr_header[]                      @relation("approved_by_user")
    rfqHeaders                   rfq_header[]                     @relation("requested_by_user")
    createdVqHeaders             vq_header[]                      @relation("VQCreatedBy")
    updatedVqHeaders             vq_header[]                      @relation("VQUpdatedBy")
    createdQcHeaders             qc_header[]                      @relation("QCCreatedBy")
    updatedQcHeaders             qc_header[]                      @relation("QCUpdatedBy")
    createdPoHeaders             po_header[]                      @relation("poCreatedBy")
    updatedPoHeaders             po_header[]                      @relation("poUpdatedBy")
    regnHeaders                  grn_header[]
    prApprovals                  pr_approval[]
    poApprovals                  po_approval[]
    employeeSaleTargets          employee_sale_target[]
    standardCostHeaders_permit   standard_cost_header[]           @relation("permit_emp")
    standardCostHeaders_save     standard_cost_header[]           @relation("save_emp")
    priceListHeaders_permit      price_list_header[]              @relation("permit_emp_price_list")
    priceListHeaders_save        price_list_header[]              @relation("save_emp_price_list")
    saleQuotationHeaders         sale_quotation_header[]
    saleQuotationApprovalHeaders sale_quotation_approval_header[]
    saleReservationHeaders       sale_reservation_header[]
    saleOrderHeaders             sale_order_header[]
    // saleOrderApprovalHeaders     sale_order_approval_header[]
    saleOrderApprovalHeaders     sale_order_approval_header[] @relation("emp_so_approval_header")
    saleOrderSaleHeaders     sale_order_approval_header[] @relation("emp_so_sale_header")
}

model employee_group {
    employee_group_id      Int     @id @default(autoincrement())
    employee_group_code    String  @unique @db.VarChar(30)
    employee_group_name    String  @db.VarChar(200)
    employee_group_nameeng String? @db.VarChar(200)
    is_active              Boolean @default(true)
}

model employee_sale_area {
    sale_area_id             Int                          @id @default(autoincrement())
    sale_area_code           String                       @unique @db.VarChar(30)
    sale_area_name           String                       @db.VarChar(200)
    sale_area_nameeng        String?                      @db.VarChar(200)
    is_active                Boolean                      @default(true)
    saleQuotationHeaders     sale_quotation_header[]
    saleReservationHeaders   sale_reservation_header[]
    saleOrderHeaders         sale_order_header[]
    saleOrderApprovalHeaders sale_order_approval_header[]
}

model employee_position {
    position_id      Int     @id @default(autoincrement())
    position_code    String  @unique @db.VarChar(30)
    position_name    String  @db.VarChar(200)
    position_nameeng String? @db.VarChar(200)
    is_active        Boolean @default(true)
}

model employee_sale_channel {
    channel_id      Int     @id @default(autoincrement())
    channel_code    String  @unique @db.VarChar(30)
    channel_name    String  @db.VarChar(200)
    channel_nameeng String? @db.VarChar(200)
    is_active       Boolean @default(true)
}

// เป้าหมายการขาย
model employee_sale_period {
    period_id     Int     @id @default(autoincrement())
    period_target Decimal @db.Decimal(18, 2)

    begin_date DateTime
    end_date   DateTime

    close_status Boolean @default(false)

    created_at          DateTime               @default(now())
    updated_at          DateTime?
    employeeSaleTargets employee_sale_target[]
}

// เป้าการขายพนักงาน
model employee_sale_target {
    target_id Int @id @default(autoincrement())
    list_no   Int @default(0)
    emp_id    Int
    period_id Int

    period_target Decimal @db.Decimal(15, 2)

    created_at DateTime             @default(now())
    updated_at DateTime?
    employee   employees            @relation(fields: [emp_id], references: [employee_id], onDelete: Cascade)
    period     employee_sale_period @relation(fields: [period_id], references: [period_id], onDelete: Cascade)

    @@unique([emp_id, period_id])
}

// รหัสฝ่าย
model employee_side {
    emp_side_id         Int                   @id @default(autoincrement())
    emp_side_code       String                @unique @db.VarChar(30)
    emp_side_name       String                @db.VarChar(200)
    emp_side_nameeng    String?               @db.VarChar(200)
    is_active           Boolean               @default(true)
    employeeDepartments employee_department[]
}

// แผนกของพนักงาน
model employee_department {
    emp_dept_id              Int                          @id @default(autoincrement())
    emp_dept_code            String                       @unique @db.VarChar(30)
    emp_dept_name            String                       @db.VarChar(200)
    emp_dept_nameeng         String?                      @db.VarChar(200)
    is_active                Boolean                      @default(true)
    emp_side_id              Int
    created_at               DateTime                     @default(now())
    updated_at               DateTime                     @updatedAt
    side                     employee_side                @relation(fields: [emp_side_id], references: [emp_side_id], onDelete: Cascade)
    priceListHeaders         price_list_header[]
    saleQuotationHeaders     sale_quotation_header[]
    saleReservationHeaders   sale_reservation_header[]
    saleOrderHeaders         sale_order_header[]
    saleOrderApprovalHeaders sale_order_approval_header[]

    @@unique([emp_dept_id])
}

/// ตารางเก็บข้อมูลบริษัท
model company {
    company_id         Int      @id @default(autoincrement())
    company_code       String   @unique @db.VarChar(20)
    company_name       String   @db.VarChar(200)
    company_nameeng    String?  @db.VarChar(200)
    company_address    String?  @db.VarChar(255)
    company_addresseng String?  @db.VarChar(255)
    company_phone      String?  @db.VarChar(20)
    company_email      String?  @db.VarChar(200)
    company_fax        String?  @db.VarChar(20)
    company_tax_id     String?  @db.VarChar(20)
    company_vat_id     String?  @db.VarChar(20)
    company_type       String?  @db.VarChar(50)
    company_status     String?  @db.VarChar(50)
    company_logo       String?  @db.VarChar(255)
    company_stamp      String?  @db.VarChar(255)
    is_active          Boolean  @default(true)
    created_at         DateTime @default(now())
    updated_at         DateTime @updatedAt
}

/// ตารางเก็บข้อมูลการ login
model employee_auth {
    employee_id Int       @id
    username    String    @unique
    password    String
    is_active   Boolean   @default(true)
    created_at  DateTime  @default(now())
    updated_at  DateTime  @updatedAt
    employee    employees @relation(fields: [employee_id], references: [employee_id], onDelete: Cascade)
}

model employee_address {
    employee_address_id Int                 @id @default(autoincrement())
    employee_id         Int
    address_type        EmployeeAddressType
    address             String
    district            String?             @db.VarChar(100)
    province            String?             @db.VarChar(100)
    postal_code         String?             @db.VarChar(10)
    country             String              @db.VarChar(100)
    contact_person      String?             @db.VarChar(255)
    employee            employees           @relation(fields: [employee_id], references: [employee_id], onDelete: Cascade)
}

/// ตารางเก็บข้อมูลสาขา 
model org_branch {
    branch_code              String                       @unique @db.VarChar(20)
    branch_name              String                       @db.VarChar(200)
    is_active                Boolean                      @default(true)
    branch_id                Int                          @id @default(autoincrement())
    created_at               DateTime                     @default(now())
    updated_at               DateTime                     @updatedAt
    employees                employees[]
    prHeaders                pr_header[]
    rfqHeaders               rfq_header[]
    warehouses               warehouse[]
    poHeaders                po_header[]
    priceListHeaders         price_list_header[]
    icOption                 ic_option[]
    saleQuotationHeaders     sale_quotation_header[]
    saleReservationHeaders   sale_reservation_header[]
    itemStockBalances        item_stock_balance[]
    stockTransactions        stock_transaction[]
    itemLotBalances          item_lot_balance[]
    lotTransactions          lot_transaction[]
    saleOrderHeaders         sale_order_header[]
    saleOrderApprovalHeaders sale_order_approval_header[]

    @@map("org_branch")
}

/// ตารางเก็บข้อมูลตำแหน่ง 
model org_position {
    position_id      Int         @id @default(autoincrement())
    position_code    String      @unique @db.VarChar(20)
    position_name    String      @db.VarChar(200)
    position_name_en String      @db.VarChar(200)
    is_active        Boolean     @default(true)
    created_at       DateTime    @default(now())
    updated_at       DateTime    @updatedAt
    employees        employees[]
}

/// ตารางเก็บข้อมูลแผนก
model org_department {
    /// รหัสแผนก
    department_id      Int         @id @default(autoincrement())
    /// รหัสแผนก
    department_code    String      @unique @db.VarChar(20)
    /// ชื่อแผนก
    department_name    String      @db.VarChar(200)
    /// ชื่อแผนก (ภาษาอังกฤษ)
    department_name_en String      @db.VarChar(200)
    /// สถานะ
    is_active          Boolean     @default(true)
    /// วันที่สร้าง
    created_at         DateTime    @default(now())
    /// วันที่แก้ไข
    updated_at         DateTime    @updatedAt
    employees          employees[]
    qcHeaders          qc_header[]
}

/// ตารางเก็บข้อมูลคลัง 
model warehouse {
    warehouse_code       String                  @unique @db.VarChar(20)
    warehouse_name       String                  @db.VarChar(200)
    warehouse_id         Int                     @id @default(autoincrement())
    branch_id            Int
    address              String?
    created_at           DateTime                @default(now())
    is_active            Boolean                 @default(true)
    updated_at           DateTime                @updatedAt
    branch               org_branch              @relation(fields: [branch_id], references: [branch_id])
    prLines              pr_line[]
    locations            location[]
    poHeaders            po_header[]
    regnHeaders          grn_header[]
    saleReservationLines sale_reservation_line[]
    itemStockBalances    item_stock_balance[]
    stockTransactions    stock_transaction[]
    itemLotBalances      item_lot_balance[]
    lotTransactions      lot_transaction[]
    saleOrderLines       sale_order_line[]

    @@map("warehouse")
}

model location {
    location_id          Int                     @id @default(autoincrement())
    warehouse_id         Int
    shelf_id             Int?
    location_code        String                  @unique @db.VarChar(20)
    location_name        String                  @db.VarChar(200)
    location_nameeng     String?                 @db.VarChar(200)
    is_active            Boolean                 @default(true)
    created_at           DateTime                @default(now())
    updated_at           DateTime                @updatedAt
    warehouse            warehouse               @relation(fields: [warehouse_id], references: [warehouse_id])
    shelf                shelf?                  @relation(fields: [shelf_id], references: [shelf_id])
    prLines              pr_line[]
    saleReservationLines sale_reservation_line[]
    itemStockBalances    item_stock_balance[]
    stockTransactions    stock_transaction[]
    itemLotBalances      item_lot_balance[]
    lotTransactions      lot_transaction[]
    saleOrderLines       sale_order_line[]

    @@map("location")
}

/// ตารางเก็บข้อมูลชั้นวางสินค้า
model shelf {
    shelf_id      Int        @id @default(autoincrement())
    shelf_code    String     @unique @db.VarChar(20)
    shelf_name    String     @db.VarChar(200)
    shelf_nameeng String?    @db.VarChar(200)
    is_active     Boolean    @default(true)
    created_at    DateTime   @default(now())
    updated_at    DateTime   @updatedAt
    locations     location[]

    @@map("shelf")
}

/// ไม่
/// ตารางเก็บข้อมูลสินค้า 
model item {
    item_id               Int           @id @default(autoincrement())
    item_code             String        @unique @db.VarChar(50)
    item_name             String        @db.VarChar(255)
    item_nameeng          String?       @db.VarChar(255)
    item_description      String?       @db.VarChar(255)
    item_descriptioneng   String?       @db.VarChar(255)
    item_type_id          Int?
    item_group_id         Int?
    item_category_id      Int?
    base_uom_id           Int?
    sale_uom_id           Int?
    tax_code_id           Int?
    barcode_default       String?       @db.VarChar(80)
    is_batch_control      Boolean       @default(false)
    is_expiry_control     Boolean       @default(false)
    is_serial_control     Boolean       @default(false)
    standard_cost         Decimal?      @db.Decimal(18, 6)
    shelf_life_days       Int?
    default_issue_policy  IssuePolicy
    lot_tracking_level    TrackingLevel
    serial_tracking_level TrackingLevel
    is_active             Boolean       @default(true)
    created_at            DateTime      @default(now())
    updated_at            DateTime      @updatedAt
    item_brand_id         Int?
    item_pattern_id       Int?
    item_design_id        Int?
    item_class_id         Int?
    item_size_id          Int?
    item_color_id         Int?
    item_grade_id         Int?

    itemBrand              item_brand?                @relation(fields: [item_brand_id], references: [item_brand_id])
    itemCategory           item_category?             @relation(fields: [item_category_id], references: [item_category_id])
    itemClass              item_class?                @relation(fields: [item_class_id], references: [item_class_id])
    itemDesign             item_design?               @relation(fields: [item_design_id], references: [item_design_id])
    itemGroup              item_group?                @relation(fields: [item_group_id], references: [item_group_id])
    itemPattern            item_pattern?              @relation(fields: [item_pattern_id], references: [item_pattern_id])
    itemSize               item_size?                 @relation(fields: [item_size_id], references: [item_size_id])
    itemType               item_type?                 @relation(fields: [item_type_id], references: [item_type_id])
    baseUom                uom?                       @relation("BaseUom", fields: [base_uom_id], references: [uom_id])
    saleUom                uom?                       @relation("SaleUom", fields: [sale_uom_id], references: [uom_id])
    itemColor              item_color?                @relation(fields: [item_color_id], references: [item_color_id])
    itemGrade              item_grade?                @relation(fields: [item_grade_id], references: [item_grade_id])
    taxCode                tax_code?                  @relation(fields: [tax_code_id], references: [tax_code_id])
    itemBarcodes           item_barcode[]
    itemUoms               item_uom[]
    prLines                pr_line[]
    rfqLines               rfq_line[]
    vqLines                vq_line[]
    poLines                po_line[]
    standardCostHeaders    standard_cost_header[]
    standardCostLines      standard_cost_line[]
    priceListItemLines     price_list_item_line[]
    multiPriceItems        multi_price_item[]
    saleQuotationLines     sale_quotation_line[]
    saleReservationLines   sale_reservation_line[]
    itemLots               item_lot[]
    itemStockBalances      item_stock_balance[]
    stockTransactions      stock_transaction[]
    itemLotBalances        item_lot_balance[]
    lotTransactions        lot_transaction[]
    saleOrderLines         sale_order_line[]
    saleOrderApprovalLines sale_order_approval_line[]

    @@index([lot_tracking_level])
    @@index([serial_tracking_level])
    @@index([default_issue_policy])
    @@map("item")
}

/// ตารางเก็บข้อมูลหน่วยนับ
model uom {
    uom_id                     Int                            @id @default(autoincrement())
    uom_code                   String                         @unique @db.VarChar(20)
    uom_name                   String                         @db.VarChar(100)
    is_active                  Boolean?                       @default(true)
    created_at                 DateTime                       @default(now())
    uom_nameeng                String?                        @db.VarChar(100)
    updated_at                 DateTime                       @updatedAt
    baseItems                  item[]                         @relation("BaseUom")
    saleItems                  item[]                         @relation("SaleUom")
    itemBarcodes               item_barcode[]
    fromItemUoms               item_uom[]                     @relation("ItemUomFrom")
    toItemUoms                 item_uom[]                     @relation("ItemUomTo")
    prLines                    pr_line[]
    rfqLines                   rfq_line[]
    vqLines                    vq_line[]
    poLines                    po_line[]
    standardCostLines          standard_cost_line[]
    priceListItemLines         price_list_item_line[]
    multiPriceItems            multi_price_item[]
    saleQuotationLines         sale_quotation_line[]
    saleQuotationApprovalLines sale_quotation_approval_line[]
    saleReservationLines       sale_reservation_line[]
    saleOrderLines             sale_order_line[]
    saleOrderApprovalLines     sale_order_approval_line[]

    @@map("uom")
}

model item_uom {
    item_uom_id     String   @id @default(uuid())
    item_id         Int
    from_uom_id     Int
    to_uom_id       Int
    factor          Decimal  @db.Decimal(18, 6)
    is_purchase_uom Boolean  @default(false)
    created_at      DateTime @default(now())
    updated_at      DateTime @updatedAt
    fromUom         uom      @relation("ItemUomFrom", fields: [from_uom_id], references: [uom_id])
    item            item     @relation(fields: [item_id], references: [item_id])
    toUom           uom      @relation("ItemUomTo", fields: [to_uom_id], references: [uom_id])

    @@unique([item_id, from_uom_id, to_uom_id])
    @@map("item_uom")
}

/// ตารางเก็บข้อมูลประเภทสินค้า
model item_type {
    /// รหัสประเภทสินค้า
    item_type_id      Int      @id @default(autoincrement())
    /// รหัสประเภทสินค้า
    item_type_code    String   @unique @db.VarChar(30)
    /// ชื่อประเภทสินค้า
    item_type_name    String   @db.VarChar(200)
    /// ชื่อประเภทสินค้า (อังกฤษ)
    item_type_nameeng String   @db.VarChar(200)
    is_active         Boolean  @default(true)
    created_at        DateTime @default(now())
    updated_at        DateTime @updatedAt
    items             item[]

    @@map("item_type")
}

/// ตารางเก็บข้อมูลบาร์โค้ดสินค้า
model item_barcode {
    /// รหัสบาร์โค้ด
    item_barcode_id Int      @id @default(autoincrement())
    /// รหัสบาร์โค้ด
    barcode         String   @unique @db.VarChar(80)
    /// รหัสสินค้า
    item_id         Int
    /// รหัสหน่วยนับ
    uom_id          Int
    /// บาร์โค้ดหลักหรือไม่
    is_primary      Boolean  @default(false)
    /// วันที่สร้างบาร์โค้ด
    created_at      DateTime @default(now())
    is_active       Boolean  @default(true)
    /// วันที่แก้ไขบาร์โค้ด
    updated_at      DateTime @updatedAt
    item            item     @relation(fields: [item_id], references: [item_id])
    uom             uom      @relation(fields: [uom_id], references: [uom_id])

    @@map("item_barcode")
}

/// ตารางเก็บข้อมูลหมวดหมู่สินค้า
model item_category {
    /// รหัสหมวดหมู่สินค้า
    item_category_id      Int      @id @default(autoincrement())
    /// รหัสหมวดหมู่สินค้า
    item_category_code    String   @unique @db.VarChar(30)
    /// ชื่อหมวดหมู่สินค้า
    item_category_name    String   @db.VarChar(200)
    /// ชื่อหมวดหมู่สินค้า (อังกฤษ)
    item_category_nameeng String?  @db.VarChar(200)
    /// สถานะการใช้งาน
    is_active             Boolean
    /// วันที่สร้าง
    created_at            DateTime @default(now())
    /// วันที่แก้ไขล่าสุด
    updated_at            DateTime @updatedAt
    items                 item[]

    @@map("item_category")
}

/// ตารางเก็บข้อมูลยี่ห้อสินค้า
model item_brand {
    /// รหัสยี่ห้อสินค้า
    item_brand_id       Int                    @id @default(autoincrement())
    /// รหัสยี่ห้อสินค้า
    item_brand_code     String                 @unique @db.VarChar(30)
    /// ชื่อยี่ห้อสินค้า
    item_brand_name     String                 @db.VarChar(200)
    /// ชื่อยี่ห้อสินค้า (อังกฤษ)
    item_brand_nameeng  String                 @db.VarChar(200)
    /// สถานะการใช้งาน
    is_active           Boolean                @default(true)
    /// วันที่สร้าง
    created_at          DateTime               @default(now())
    /// วันที่แก้ไขล่าสุด
    updated_at          DateTime               @updatedAt
    items               item[]
    standardCostHeaders standard_cost_header[]

    @@map("item_brand")
}

/// ตารางเก็บข้อมูลลายสินค้า รูปแบบสินค้า
model item_pattern {
    /// รหัสลายสินค้า
    item_pattern_id      Int      @id @default(autoincrement())
    /// รหัสลายสินค้า
    item_pattern_code    String   @unique @db.VarChar(30)
    /// ชื่อลายสินค้า
    item_pattern_name    String   @db.VarChar(200)
    /// ชื่อลายสินค้า (อังกฤษ)
    item_pattern_nameeng String?  @db.VarChar(200)
    /// สถานะการใช้งาน
    is_active            Boolean? @default(true)
    /// วันที่สร้าง
    created_at           DateTime @default(now())
    /// วันที่แก้ไขล่าสุด
    updated_at           DateTime @updatedAt
    items                item[]

    @@map("item_pattern")
}

model item_design {
    /// รหัสลายสินค้า
    item_design_id      Int      @id @default(autoincrement())
    /// รหัสลายสินค้า
    item_design_code    String   @unique @db.VarChar(30)
    /// ชื่อลายสินค้า
