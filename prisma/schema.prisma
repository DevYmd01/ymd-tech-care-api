    /// วันที่ของเรท ui input
    exchange_rate_date  DateTime?

    /// จำนวนเงินรวม (Base Currency)
    base_total_amount  Decimal @db.Decimal(18, 2)
    /// จำนวนเงินรวม (Quote Currency)
    quote_total_amount Decimal @db.Decimal(18, 2)

    /// TAX
    tax_code_id      Int?
    tax_rate         Decimal? @db.Decimal(9, 4)
    base_tax_amount  Decimal? @db.Decimal(18, 2)
    quote_tax_amount Decimal? @db.Decimal(18, 2)

    /// DOCUMENT DISCOUNT
    discount_expression   String?      @db.VarChar(20)
    discount_rate         Decimal?     @db.Decimal(9, 4)
    base_discount_amount  Decimal?     @db.Decimal(18, 2)
    quote_discount_amount Decimal?     @db.Decimal(18, 2)
    created_by            Int?
    updated_by            Int?
    created_at            DateTime     @default(now())
    updated_at            DateTime     @updatedAt
    //ใช้ตอน qc
    is_awarded            Boolean      @default(false)
    pr                    pr_header    @relation(fields: [pr_id], references: [pr_id])
    rfq                   rfq_header   @relation(fields: [rfq_id], references: [rfq_id])
    rfq_vendor            rfq_vendor?  @relation(fields: [rfq_vendor_id], references: [rfq_vendor_id])
    vendor                vendor       @relation(fields: [vendor_id], references: [vendor_id])
    tax_code              tax_code?    @relation(fields: [tax_code_id], references: [tax_code_id])
    createdVqHeaders      employees?   @relation("VQCreatedBy", fields: [created_by], references: [employee_id])
    updatedVqHeaders      employees?   @relation("VQUpdatedBy", fields: [updated_by], references: [employee_id])
    pr_approval           pr_approval? @relation(fields: [pr_approval_id], references: [approval_id])
    vqLines               vq_line[]
    qcHeaders             qc_header[]
}

model vq_line {
    /// รหัสใบเสนอราคา (PK)
    vq_line_id   Int  @id @default(autoincrement())
    vq_header_id Int
    /// ลำดับ
    line_no      Int
    /// รหัสสินค้า (FK)
    item_id      Int?
    /// รหัสใบขอซื้อ (FK)
    pr_line_id   Int

    approval_line_id Int?
    /// รายละเอียด
    description      String? @db.VarChar(255)

    /// สถานะ
    status              String            @db.VarChar(20)
    /// จำนวน
    qty                 Decimal           @db.Decimal(18, 6)
    /// รหัสหน่วยนับ (FK)
    uom_id              Int
    /// ราคาต่อหน่วย
    unit_price          Decimal           @db.Decimal(18, 2)
    /// ส่วนลดต่อบรรทัด 
    discount_amount     Decimal?          @db.Decimal(9, 4)
    /// % ส่วนลด(string) 
    discount_rate       Decimal?          @db.Decimal(9, 4)
    /// % ส่วนลด(คำนวณจาก discount_rate)จาก UI
    discount_expression String?           @db.VarChar(20)
    net_amount          Decimal           @db.Decimal(18, 2)
    created_at          DateTime          @default(now())
    updated_at          DateTime          @updatedAt
    vq                  vq_header         @relation(fields: [vq_header_id], references: [vq_header_id])
    item                item?             @relation(fields: [item_id], references: [item_id])
    prLine              pr_line           @relation(fields: [pr_line_id], references: [pr_line_id])
    approval_line       pr_approval_line? @relation(fields: [approval_line_id], references: [approval_line_id])
    uom                 uom               @relation(fields: [uom_id], references: [uom_id])
}

model qc_header {
    /// รหัสใบเปรียบเทียบราคา (PK)
    qc_id            Int             @id @default(autoincrement())
    /// เลขที่ใบเปรียบเทียบราคา
    qc_no            String          @unique @db.VarChar(30)
    /// รหัสใบขอซื้อ (FK)
    pr_id            Int
    /// รหัสใบขอซื้อ (FK)
    rfq_id           Int
    /// แผนกที่ขอ
    department_id    Int?
    /// รหัสใบขอซื้อ (FK) ผู้ชนะ
    winning_vq_id    Int
    /// หมายเหตุ
    remarks          String?         @db.Text
    /// สถานะ
    status           String          @db.VarChar(20)
    /// วันที่สร้าง
    created_at       DateTime        @default(now())
    /// วันที่แก้ไขล่าสุด
    updated_at       DateTime        @updatedAt
    created_by       Int?
    updated_by       Int?
    pr               pr_header       @relation(fields: [pr_id], references: [pr_id])
    rfq              rfq_header      @relation(fields: [rfq_id], references: [rfq_id])
    createdQcHeaders employees?      @relation("QCCreatedBy", fields: [created_by], references: [employee_id])
    updatedQcHeaders employees?      @relation("QCUpdatedBy", fields: [updated_by], references: [employee_id])
    winningVq        vq_header?      @relation(fields: [winning_vq_id], references: [vq_header_id])
    department       org_department? @relation(fields: [department_id], references: [department_id])
    poHeaders        po_header[]
}

model po_header {
    /// รหัสใบสั่งซื้อ (PK)
    po_header_id Int      @id @default(autoincrement())
    /// เลขที่ใบสั่งซื้อ
    po_no        String   @unique @db.VarChar(30)
    /// วันที่ใบสั่งซื้อ
    po_date      DateTime @default(now())
    /// รหัสใบขอซื้อ (FK)
    pr_id        Int?
    qc_id        Int?

    /// รหัสผู้ขาย (FK)
    vendor_id    Int
    /// รหัสสาขา (FK)
    branch_id    Int
    /// รหัสคลังสินค้า (FK)
    warehouse_id Int?
    /// สถานะ
    status       String   @db.VarChar(20)
    /// วันที่สร้าง
    created_at   DateTime @default(now())
    /// วันที่แก้ไขล่าสุด
    updated_at   DateTime @updatedAt
    created_by   Int?
    updated_by   Int?

    /// สกุลเงินหลักของระบบ (Functional Currency)
    base_currency_code  String?   @db.VarChar(3)
    /// สกุลเงินตามใบเสนอราคา (Vendor Currency)
    quote_currency_code String?   @db.VarChar(3)
    /// อัตราแลกเปลี่ยน (1 quote → base) ui input
    exchange_rate       Decimal?  @db.Decimal(18, 6)
    /// วันที่ของเรท ui input
    exchange_rate_date  DateTime?

    /// จำนวนเงินรวม (Base Currency)
    base_total_amount  Decimal @db.Decimal(18, 2)
    /// จำนวนเงินรวม (Quote Currency)
    quote_total_amount Decimal @db.Decimal(18, 2)

    /// TAX
    tax_code_id      Int?
    tax_rate         Decimal? @db.Decimal(9, 4)
    base_tax_amount  Decimal? @db.Decimal(18, 2)
    quote_tax_amount Decimal? @db.Decimal(18, 2)

    /// DOCUMENT DISCOUNT
    discount_expression   String?  @db.VarChar(20)
    discount_rate         Decimal? @db.Decimal(9, 4)
    base_discount_amount  Decimal? @db.Decimal(18, 2)
    quote_discount_amount Decimal? @db.Decimal(18, 2)

    pr               pr_header?    @relation(fields: [pr_id], references: [pr_id])
    qc               qc_header?    @relation(fields: [qc_id], references: [qc_id])
    createdPoHeaders employees?    @relation("poCreatedBy", fields: [created_by], references: [employee_id])
    updatedPoHeaders employees?    @relation("poUpdatedBy", fields: [updated_by], references: [employee_id])
    vendor           vendor        @relation(fields: [vendor_id], references: [vendor_id])
    branch           org_branch    @relation(fields: [branch_id], references: [branch_id])
    warehouse        warehouse?    @relation(fields: [warehouse_id], references: [warehouse_id])
    poLines          po_line[]
    tax_code         tax_code?     @relation(fields: [tax_code_id], references: [tax_code_id])
    regnHeaders      grn_header[]
    poApprovals      po_approval[]
}

model po_line {
    /// รหัสใบสั่งซื้อ (PK)
    po_line_id   Int  @id @default(autoincrement())
    /// เลขที่ใบสั่งซื้อ
    po_header_id Int
    /// ลำดับบรรทัด
    line_no      Int
    /// รหัสใบขอซื้อ (FK)
    pr_line_id   Int?
    rfq_line_id  Int?

    /// รหัสสินค้า (FK)
    item_id     Int?
    description String? @db.VarChar(255)

    /// ประเภทการรับ GOODS/SERVICE
    required_receipt_type String? @db.VarChar(20)

    /// สถานะ
    status          String   @db.VarChar(20)
    /// วันที่สร้าง
    created_at      DateTime @default(now())
    /// วันที่แก้ไขล่าสุด
    updated_at      DateTime @updatedAt
    /// จำนวนที่สั่งซื้อ
    qty             Decimal  @db.Decimal(18, 2)
    /// หน่วยนับ
    uom_id          Int
    /// ราคาต่อหน่วย
    unit_price      Decimal  @db.Decimal(18, 2)
    /// ส่วนลด
    discount_amount Decimal  @db.Decimal(18, 2)

    /// TAX
    tax_code_id Int?
    tax_rate    Decimal? @db.Decimal(9, 4)

    /// DOCUMENT DISCOUNT
    discount_expression String?  @db.VarChar(20)
    discount_rate       Decimal? @db.Decimal(9, 4)

    net_amount Decimal @db.Decimal(18, 2)

    // จำนวนที่อนุมัติ
    approved_qty  Decimal @default(0)
    // จำนวนที่ปฏิเสธ
    rejected_qty  Decimal @default(0)
    // จำนวนที่ยังค้างอยู่จากการอนุมัติ
    remaining_qty Decimal @default(0)

    poHeader        po_header          @relation(fields: [po_header_id], references: [po_header_id])
    prLine          pr_line?           @relation(fields: [pr_line_id], references: [pr_line_id])
    rfqLine         rfq_line?          @relation(fields: [rfq_line_id], references: [rfq_line_id])
    uom             uom                @relation(fields: [uom_id], references: [uom_id])
    taxCode         tax_code?          @relation(fields: [tax_code_id], references: [tax_code_id])
    item            item?              @relation(fields: [item_id], references: [item_id])
    poApprovalLines po_approval_line[]
}

model po_approval {
    approval_id       Int       @id @default(autoincrement())
    approval_no       String    @db.VarChar(30)
    approval_date     DateTime  @db.Date
    need_by_date      DateTime? @db.Date
    status            String    @db.VarChar(20)
    remarks           String?   @db.Text
    created_at        DateTime  @default(now())
    updated_at        DateTime  @updatedAt
    // รหัสผู้อนุมัติ (FK)
    approval_emp_id   Int
    approval_emp_name String    @db.VarChar(255)

    po_header_id Int

    /// สกุลเงินหลักของระบบ (Functional Currency)
    base_currency_code    String?   @db.VarChar(3)
    base_currency_id      Int?
    /// สกุลเงินตามใบเสนอราคา (Vendor Currency)
    quote_currency_code   String?   @db.VarChar(3)
    quote_currency_id     Int?
    /// อัตราแลกเปลี่ยน (1 quote → base) ui input
    exchange_rate         Decimal?  @db.Decimal(18, 6)
    /// วันที่ของเรท ui input
    exchange_rate_date    DateTime?
    /// จำนวนเงินรวม (Base Currency)
    base_total_amount     Decimal   @db.Decimal(18, 2)
    /// จำนวนเงินรวม (Quote Currency)
    quote_total_amount    Decimal   @db.Decimal(18, 2)
    /// TAX
    tax_code_id           Int?
    tax_rate              Decimal?  @db.Decimal(9, 4)
    base_tax_amount       Decimal?  @db.Decimal(18, 2)
    quote_tax_amount      Decimal?  @db.Decimal(18, 2)
    /// DOCUMENT DISCOUNT
    discount_expression   String?   @db.VarChar(20)
    discount_rate         Decimal?  @db.Decimal(9, 4)
    base_discount_amount  Decimal?  @db.Decimal(18, 2)
    quote_discount_amount Decimal?  @db.Decimal(18, 2)

    // 🔗 Relations (แนะนำให้มี)
    poHeader        po_header          @relation(fields: [po_header_id], references: [po_header_id])
    approval_emp    employees          @relation(fields: [approval_emp_id], references: [employee_id])
    base_currency   currency?          @relation("po_approval-base_currency", fields: [base_currency_id], references: [currency_id])
    quote_currency  currency?          @relation("po_approval-quote_currency", fields: [quote_currency_id], references: [currency_id])
    tax_code        tax_code?          @relation(fields: [tax_code_id], references: [tax_code_id])
    poApprovalLines po_approval_line[]

    @@map("po_approval")
}

model po_approval_line {
    approval_line_id Int @id @default(autoincrement())

    po_line_id  Int
    approval_id Int

    approved_qty Decimal @db.Decimal(18, 3)
    // PENDING / APPROVED / REJECTED
    status       String

    remarks String? @db.Text

    approved_at DateTime?
    approved_by Int?

    // optional แต่โคตร useful // version control
    is_active Boolean @default(true)

    created_at DateTime @default(now())
    updated_at DateTime @updatedAt

    approval po_approval @relation(fields: [approval_id], references: [approval_id])
    po_line  po_line     @relation(fields: [po_line_id], references: [po_line_id])

    @@map("approval_po_line")
}

model grn_header {
    /// รหัสใบรับสินค้า (PK)
    grn_id       Int        @id @default(autoincrement())
    /// เลขที่ใบรับสินค้า
    grn_no       String     @unique @db.VarChar(30)
    /// รหัสใบสั่งซื้อ (FK)
    po_header_id Int
    /// วันที่ใบรับสินค้า
    grn_date     DateTime   @default(now())
    /// สถานะ
    status       String     @db.VarChar(20)
    /// รหัสผู้รับสินค้า (FK)
    received_by  Int?
    /// รหัสสาขา (FK)
    branch_id    Int?
    /// รหัสคลังสินค้า (FK)
    warehouse_id Int?
    /// หมายเหตุ
    remarks      String?    @db.Text
    /// วันที่สร้าง
    created_at   DateTime   @default(now())
    /// วันที่แก้ไขล่าสุด
    updated_at   DateTime   @updatedAt
