model grn_line {
    /// รหัสใบรับสินค้า (PK)
    grn_line_id  Int     @id @default(autoincrement())
    /// รหัสใบรับสินค้า (FK)
    grn_id       Int
    /// ลำดับ
    line_no      Int
    /// รหัสสินค้า (FK)
    item_id      Int?
    /// รหัสสินค้า (FK)
    pr_line_id   Int
    /// รายละเอียด
    description  String? @db.VarChar(255)
    /// จำนวน
    qty_received Decimal @db.Decimal(18, 6)
    /// รหัสหน่วยนับ (FK)
    uom_id       Int
}

